# Environment variables for deck generator LLM provider.
# Copy this file to .env and fill in ONE provider's credentials.

# --- Azure OpenAI (recommended if you have an Azure subscription) ---
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-key-here
# AZURE_OPENAI_MODEL=gpt-4o

# --- OpenAI ---
# OPENAI_API_KEY=sk-...

# --- Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Ollama (no config needed, just run: ollama serve) ---
# Uses http://localhost:11434 by default
